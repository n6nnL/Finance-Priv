# ============================================================
#  Bank Email Listener — орчны хувьсагчид (.env.example)
#  Энэ файлыг хуулж .env болгоод бодит утгаар бөглөнө.
#  .env-г GIT-д ХЭЗЭЭ Ч commit ХИЙХГҮЙ.
# ============================================================

# ---- Gmail хаяг (LEGACY — зөвхөн owner seed-д, GMAIL_REFRESH_TOKEN-тэй хамт) ----
# Multi-tenant үед данс бүрийн хаяг DB-ээс (холбогдсон inbox-ийн бодит хаяг) ирнэ.
GMAIL_USER=youraddress@gmail.com

# ---- Google OAuth2 (Google Cloud Console-оос авна) ----
# ⚠️ ЭНЭ (Desktop/Installed-type) client зөвхөн owner-ийн legacy seed-д
# (scripts/get-token.js). Dashboard-ийн Google Login/Calendar ТУСДАА
# (Web-type) client ашигладаг — тохиргоо: api/.env.example (LOGIN_GOOGLE_CLIENT_ID г.м).
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# LEGACY — зөвхөн анхны owner seed-д. Multi-tenant үед хэрэглэгч бүр (owner ч мөн)
# dashboard-ийн Settings-ээс Gmail-аа холбоно; token нь API DB-д шифрлэгдэж хадгалагдана.
# Энэ утга байвал listener эхлэхдээ owner-ийн холболт болгож НЭГ УДАА DB-д оруулна.
GMAIL_REFRESH_TOKEN=your-refresh-token
# ⚠️ ЗААВАЛ (multi-tenant) — api/.env-ийн GMAIL_GOOGLE_CLIENT_ID/SECRET-тэй ЯГ
# ИЖИЛ утга. Dashboard Settings-ээс Gmail холбосон хэрэглэгчийн token ЭНЭ
# (Web-type) client-ээр олгогддог тул listener мөн ЯГ ЭНЭ client-ээр л сэргээж
# чадна (Google өөр client-ээр refresh-ийг 'unauthorized_client'-ээр татгалздаг).
# Дутуу бол Settings-ээс холбосон хэрэглэгчдийн listener мөнхөд унана.
GMAIL_GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
GMAIL_GOOGLE_CLIENT_SECRET=your-web-client-secret

# ---- Multi-tenant listener ----
# API-ийн SQLite файлын зам — listener эндээс холбогдсон Gmail дансуудыг уншина.
# (pm2 cwd-ээс харьцангуй эсвэл absolute. Серверт: /home/<user>/<repo>/api/data/transactions.sqlite)
API_DB_PATH=./api/data/transactions.sqlite
# Token шифрлэлтийн түлхүүр — api/.env-ийн TOKEN_ENC_KEY-тэй ЯГ ИЖИЛ (ЗААВАЛ).
TOKEN_ENC_KEY=
# Данс нэмэгдсэн/хасагдсаныг шалгах интервал (секунд). Default 60.
ACCOUNTS_POLL_SECONDS=60

# get-token.js дотор ашиглах redirect URI (Google Cloud-д бүртгэсэн байх ёстой)
OAUTH_REDIRECT_URI=http://localhost:53682/oauth2callback

# ---- Банкны илгээгчийн хаяг (шүүлт) ----
# Зөвхөн энэ хаягаас ирсэн имэйлийг боловсруулна
BANK_SENDER=alert@golomtbank.com

# ---- Сонсох mailbox ----
IMAP_MAILBOX=INBOX

# ---- Вэбсайтын API (гүйлгээ POST хийх endpoint) ----
WEBSITE_API_URL=https://example.com/api/transactions
WEBSITE_API_KEY=your-api-key
# HMAC ашиглах бол доорхыг бөглө (хоосон бол зөвхөн API key header явна)
WEBSITE_HMAC_SECRET=

# ---- Өгөгдлийн сангийн зам ----
DB_PATH=./data/listener.sqlite

# ---- Token refresh интервал (минут). Access token ~60 мин амьдардаг тул 50 байх нь зүйтэй ----
TOKEN_REFRESH_MINUTES=50

# ---- Heartbeat интервал (секунд) ----
HEARTBEAT_SECONDS=300

# ---- Сүүлийн имэйлээс хойш энэ хугацаанаас (минут) удвал warning ----
IDLE_WARN_MINUTES=720

# ---- Push retry тоо ----
PUSH_MAX_RETRIES=4

# ---- Лог түвшин (trace|debug|info|warn|error) ----
LOG_LEVEL=info

# ---- Операцийн сэрэмжлүүлэг (Discord webhook) ----
# Ноцтой/давтагдах алдаа (OAuth invalid_grant, IMAP reconnect loop,
# unhandledRejection/uncaughtException) гарвал ЭНЭ webhook руу шууд мэдэгдэнэ.
# Хоосон бол сэрэмжлүүлэг унтраалттай (системд нөлөөлөхгүй).
# ⚠️ Бодит URL-г GIT-д оруулахгүй.
OPS_WEBHOOK_URL=
# (Сонголт) сэрэмжлүүлэгт харагдах процессын нэр
OPS_PROCESS_NAME=bank-listener

# ---- Discord bot (мэдэгдэл + товчоор ангилах) — ЗӨВХӨН owner ----
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
# (Сонголт) bot нь WEBSITE_API_KEY-г ашиглана; өөр key хүсвэл DISCORD_API_KEY
# DISCORD_API_BASE=http://localhost:3000
# DISCORD_POLL_SECONDS=15

# ---- Telegram bot (мэдэгдэл + linking + товчоор ангилах) — БҮХ хэрэглэгч ----
# @BotFather-аас bot үүсгэж авсан token.
TELEGRAM_BOT_TOKEN=
# ⚠️ api/.env-ийн JWT_SECRET-тэй ЯГ ИЖИЛ байх ЗААВАЛ (fallback байхгүй, энд
# ЗААВАЛ бөглөнө). Bot энэ секретээр тухайн хэрэглэгчид зориулсан богино
# хугацаат access token-ыг ӨӨРӨӨ mint хийж, API-д Bearer-ээр илгээдэг (HTTP
# round-trip хэрэггүй). Үүсгэх: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
# Dashboard-ийн нийтэд харагдах хаяг (bot-ийн onboarding зааварт харуулна)
DASHBOARD_PUBLIC_URL=https://golomt-fin.duckdns.org
# TELEGRAM_API_BASE=http://localhost:3000
# TELEGRAM_DB_PATH=../api/data/transactions.sqlite
# TELEGRAM_POLL_SECONDS=15
# TELEGRAM_JWT_TTL=5m
