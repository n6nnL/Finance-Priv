# ============================================================
#  Bank Transactions API — орчны хувьсагчид (.env.example)
#  Хуулж .env болгон бодит утгаар бөглөнө. .env-г GIT-д ОРУУЛАХГҮЙ.
# ============================================================

# ---- Сервер ----
PORT=3000

# ---- Authentication ----
# Listener тал энэ key-г X-API-Key (эсвэл Authorization: Bearer) header-т явуулна.
# ⚠️ Listener талын WEBSITE_API_KEY-тэй ЯГ ИЖИЛ байх ёстой.
LISTENER_API_KEY=replace-with-a-long-random-secret

# (Сонголт) HMAC баталгаажуулалт. Тохируулбал listener body-г энэ secret-ээр
# sign хийж X-Signature header-т явуулна. Listener талын WEBSITE_HMAC_SECRET-тэй
# ЯГ ИЖИЛ байх ёстой. Хоосон бол зөвхөн API key шалгана.
LISTENER_HMAC_SECRET=

# ---- Өгөгдлийн сан (SQLite) ----
DB_PATH=./data/transactions.sqlite

# ---- Rate limiting (нэг API key + IP-д) ----
# Цонхны хугацаа (секунд) болон тухайн цонхонд зөвшөөрөх дээд хүсэлт
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX=120

# ---- Body хэмжээний хязгаар ----
BODY_LIMIT=100kb

# ---- Хуучирсан pending → авто 'Бусад' ----
# Ангилаагүй (pending_review) гүйлгээ N хоногоос дээш хугацаанд байвал автоматаар
# 'Бусад' болгоно (гараар зассныг хөндөхгүй). 0 → унтраалттай. Default 3.
PENDING_AUTO_CLASSIFY_DAYS=3

# ---- Лог түвшин ----
LOG_LEVEL=info

# ---- Операцийн сэрэмжлүүлэг (Discord webhook) ----
# Сервер тал: unhandledRejection/uncaughtException болон тогтвортой 5xx
# (5 минутад ≥5) гарвал ЭНЭ webhook руу шууд мэдэгдэнэ. Хоосон бол унтраалттай.
# ⚠️ Бодит URL-г GIT-д оруулахгүй.
OPS_WEBHOOK_URL=
OPS_PROCESS_NAME=bank-api

# ---- Dashboard нэвтрэлт (хэрэглэгчийн нэр/нууц үг) ----
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=

# ---- JWT (хэрэглэгчийн dashboard session) ----
# Тохируулаагүй бол LISTENER_API_KEY-г секрет болгож ашиглана (fallback).
# ⚠️ Telegram bot (root .env, telegram/) ЭНЭ секретээр хэрэглэгчийн нэрийн
# өмнөөс access token mint хийдэг тул ЭНД ТОДОРХОЙ БИЧИЖ, root .env-ийн
# JWT_SECRET-тэй ЯГ ИЖИЛ утга тавина уу (эс бөгөөс Telegram-ийн ангилах товч
# ажиллахгүй болно). Үүсгэх: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ---- Token encryption at rest (ЗААВАЛ) ----
# OAuth refresh token (Gmail/Calendar)-ыг DB-д хадгалахын өмнө AES-256-GCM-ээр
# шифрлэх мастер түлхүүр. Үүсгэх:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠️ Root .env-ийн TOKEN_ENC_KEY-тэй ЯГ ИЖИЛ байх ёстой (listener мөн уншдаг).
# Түлхүүр солигдвол хадгалагдсан бүх token тайлагдахгүй болно — сольж БОЛОХГҮЙ.
TOKEN_ENC_KEY=

# ---- Gmail холболт (multi-tenant listener) ----
# Хэрэглэгч Settings-ээс Gmail-аа холбоход ашиглах OAuth client — listener-ийн
# Gmail client-тэй ИЖИЛ (root .env-ийн GOOGLE_CLIENT_ID/SECRET утгыг энд давхар тавь).
# Тухайн client дээр Google Console-д redirect URI нэм:
#   http://localhost:3000/api/auth/gmail/callback   (prod: https://<домейн>/api/auth/gmail/callback)
GMAIL_GOOGLE_CLIENT_ID=
GMAIL_GOOGLE_CLIENT_SECRET=

# ---- Хүний нэвтрэлт: GOOGLE OAuth (Login) — Calendar-аас ТУСДАА client ----
# Хүн зөвхөн Google-ээр нэвтэрнэ (минимал scope: openid/email/profile — "баталгаажаагүй
# апп" анхааруулга гарахгүй). Email/нууц үг нэвтрэлт default UNTRAALTTAI.
# ⚠️ ЭНЭ client нь listener-ийн Gmail IMAP client-ээс (root .env, GOOGLE_CLIENT_ID)
# ТУСДАА байх ёстой! Google Cloud Console дээр шинэ "Web application" OAuth client
# үүсгэж, Authorized redirect URI-д ХОЁРЫГ нэм:
#   http://localhost:3000/api/auth/google/callback            (login)
#   http://localhost:3000/api/auth/google/calendar/callback   (Calendar холбох, Settings-ээс)
# (prod: https://<домейн>/api/auth/google/callback болон .../google/calendar/callback).
# Calendar холбоход Google Calendar API-г асааж, consent screen-д calendar.readonly
# scope нэмнэ (энэ нь login-д БИШ, зөвхөн Settings-ийн "Календарь холбох" товч дарахад асуугдана).
LOGIN_GOOGLE_CLIENT_ID=your-login-client-id.apps.googleusercontent.com
LOGIN_GOOGLE_CLIENT_SECRET=your-login-client-secret
LOGIN_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
# Зөвхөн эдгээр Google email нэвтэрнэ (таслалаар тусгаарла). AUTH_OPEN_SIGNUP=true
# үед энэ шалгалт алгасагдана.
GOOGLE_ALLOWED_EMAILS=you@gmail.com
# true бол allow-list-гүйгээр ямар ч Google хэрэглэгч бүртгүүлж нэвтэрнэ (шинэ
# хэрэглэгч зөвхөн өөрийн (хоосон) өгөгдлийг харна). Default false — хувийн систем.
AUTH_OPEN_SIGNUP=false
# Нэвтэрсний дараа browser-г буцаах SPA суурь. Prod (нэг origin) → хоосон орхи.
# Dev (Vite :5173 тусдаа) → http://localhost:5173
DASHBOARD_BASE_URL=

# Email/нууц үг нэвтрэлт (UI-д байхгүй; зөвхөн яаралтай/тест). Default false.
AUTH_LOCAL_ENABLED=false

# ---- AI ангилал (Claude API) — СОНГОЛТТОЙ ----
# Default унтраалттай. Идэвхжүүлэх: AI_CATEGORIZATION_ENABLED=true + хүчинтэй key.
# AI-гүй үед систем бүрэн ажиллана (танигдаагүй → саналгүй pending_review).
AI_CATEGORIZATION_ENABLED=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
